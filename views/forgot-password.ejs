<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="This is a budget web app tool created by Dennis Williams">

    <link rel="stylesheet" type="text/css" href="../CSS/main.css">.
    <link rel="stylesheet" type="text/css" href="../CSS/password-reset.css">
    <link rel="icon" type="image" href="https://img.icons8.com/dusk/2x/coin-in-hand.png">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.2/css/all.css" integrity="sha384-vSIIfh2YWi9wW0r9iZe7RJPrKwp6bG+s9QZMoITbCckVJqGCCRhc+ccxNcdpHuYu" crossorigin="anonymous">

    
    <title>Budget App | Forgot Password</title>
</head>
<body>
    <button id="nav-btn" onclick="toggleMenu()">
        <i id="bars" class="fas fa-bars"></i>
    </button>

    <!--Navbar-->
    <div id="navbar" class="navbar">
        <button id="close-btn">
            <i id="x" class="fas fa-times"></i>
        </button>
        <center>
            <h1>Budget App <i class="fas fa-dollar-sign"></i></h1>
        </center>
        <div class="profile">
            <center>
                <img id="profile-pic" src="https://scontent-mia3-1.xx.fbcdn.net/v/t1.0-9/134574977_10164534556210029_4648571340648971460_o.jpg?_nc_cat=100&ccb=2&_nc_sid=0debeb&_nc_ohc=scPJu0joNUgAX-PWtr7&_nc_ht=scontent-mia3-1.xx&oh=601d89ac872ec01222f36903ccdaa84e&oe=602C8969" alt="Profile Picture">
                <h3>Profile Name</h3>
                <a href="../HTML/profile.html" target="_self">View Profile</a>
            </center>
        </div>
        <div class="links-area">
            <ul>
                <li class="list"><a href="../HTML/index.html" class="links"><i class="fas fa-home"></i> Summary</a></li>
                <li class="list"><a href="../HTML/expenses.html" class="links"><i class="fas fa-hand-holding-usd"></i> Expenses</a></li>
                <li class="list"><a href="../HTML/income.html" class="links"><i class="fas fa-wallet"></i> Income</a></li>
                <li class="list"><a href="../HTML/savings.html" class="links"><i class="fas fa-piggy-bank"></i> Savings</a></li>
                <li class="list"><a href="../HTML/atm-map.html" class="links"><i class="fas fa-map-marked-alt"></i> ATM Map</a></li>
                <li class="list"><a href="../HTML/report-error.html" class="links"><i class="fas fa-bug"></i> Report Issue</a></li>
            </ul>
        </div>
        <div class="app-info">
            <p class="app-details">Version 1.0</p>
            <p class="app-details">Copyright BudgetApp 2021 &copy;</p>
        </div>
        <button id="button"><a href="../HTML/login.html" style="color: black;"> Logout <i class="fas fa-sign-out-alt"></i></a></button>
    </div>
    <!--Navbar-->

    <main>
        <div class="box">
            <h1 class="reset-title">Forgot your password?</h1>
            <p class="reset-description">No worries! Resetting your password is easy. We'll email you a link to reset your password. Enter the email associated with your account to get started.</p>
            <form>
                <input id="email" type="email" minlength="1" placeholder="Email@example.com" required>
                <br>
                <input id="btn-reset" type="submit" value="Reset Password">
            </form>
        </div>
    </main>
    <footer>
        <p id="copyright">&#9426 Budget App Password Reset Form. All Rights Reserved | Designed by Dennis Williams.</p>
    </footer>
</body>
<script type="text/javascript" src="../JS/action.js"></script>
</html>